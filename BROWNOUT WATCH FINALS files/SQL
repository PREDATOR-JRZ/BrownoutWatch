CREATE TABLE users (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    username TEXT,
    password TEXT,
    role TEXT
);

CREATE TABLE zones (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    zone_name TEXT
);

CREATE TABLE outages (
    id INTEGER PRIMARY KEY AUTOINCREMENT,
    zone TEXT,
    duration REAL,
    cause TEXT,
    date TEXT
);

